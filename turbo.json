{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true,
      "passThroughEnv": ["*"]
    },
    "start:prod": {
      "dependsOn": ["build", "^build"],
      "cache": false,
      "persistent": true,
      "passThroughEnv": ["*"]
    },
    "clean": {
      "cache": false
    },
    "lint": {},
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["build", "^build"]
    },
    "bench": {
      "dependsOn": ["build", "^build"]
    },
    "test:integration": {
      "dependsOn": ["build", "^build"]
    },
    "test:e2e": {
      "dependsOn": ["build", "^build"]
    }
  }
}
