{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "bundle": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "@bb/host-daemon#build": {
      "dependsOn": ["bundle", "^build"],
      "outputs": ["dist/**"]
    },
    "template:build": {
      "dependsOn": ["build", "^build"],
      "cache": false,
      "outputs": [],
      "passThroughEnv": ["E2B_API_KEY"]
    },
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true,
      "passThroughEnv": ["*"]
    },
    "@bb/server#dev": {
      "dependsOn": ["build", "^build"],
      "cache": false,
      "persistent": true,
      "passThroughEnv": ["*"]
    },
    "@bb/host-daemon#dev": {
      "dependsOn": ["build", "^build"],
      "cache": false,
      "persistent": true,
      "passThroughEnv": ["*"]
    },
    "start:prod": {
      "dependsOn": ["build", "^build"],
      "cache": false,
      "persistent": true,
      "passThroughEnv": ["*"]
    },
    "clean": {
      "cache": false
    },
    "lint": {},
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["build", "^build"]
    },
    "test:smoke": {
      "dependsOn": ["build", "^build"]
    },
    "bench": {
      "dependsOn": ["build", "^build"]
    },
    "test:integration": {
      "dependsOn": ["build", "^build"]
    },
    "test:e2e": {
      "dependsOn": ["build", "^build"]
    }
  }
}
