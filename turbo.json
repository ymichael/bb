{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "bundle": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "@bb/host-daemon#build": {
      "dependsOn": ["bundle", "^build"],
      "outputs": ["dist/**"]
    },
    "@bb/agent-fixtures#build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "template:build": {
      "dependsOn": ["build", "^build"],
      "cache": false,
      "outputs": [],
      "passThroughEnv": ["E2B_API_KEY"]
    },
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true,
      "passThroughEnv": ["*"]
    },
    "@bb/server#dev": {
      "dependsOn": ["build", "^build"],
      "cache": false,
      "persistent": true,
      "passThroughEnv": ["*"]
    },
    "@bb/host-daemon#dev": {
      "dependsOn": ["build", "^build"],
      "cache": false,
      "persistent": true,
      "passThroughEnv": ["*"]
    },
    "start:prod": {
      "dependsOn": ["build", "^build"],
      "cache": false,
      "persistent": true,
      "passThroughEnv": ["*"]
    },
    "clean": {
      "cache": false
    },
    "lint": {},
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "@bb/integration-tests#build": {
      "dependsOn": ["^build"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/apps/server/package.json",
        "$TURBO_ROOT$/apps/server/tsconfig.json",
        "$TURBO_ROOT$/apps/server/src/**"
      ],
      "outputs": []
    },
    "@bb/integration-tests#typecheck": {
      "dependsOn": ["^build"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/apps/server/package.json",
        "$TURBO_ROOT$/apps/server/tsconfig.json",
        "$TURBO_ROOT$/apps/server/src/**"
      ]
    },
    "test": {
      "dependsOn": ["build", "^build"]
    },
    "@bb/integration-tests#test": {
      "dependsOn": ["build", "^build"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/apps/server/package.json",
        "$TURBO_ROOT$/apps/server/tsconfig.json",
        "$TURBO_ROOT$/apps/server/src/**"
      ]
    },
    "test:smoke": {
      "dependsOn": ["build", "^build"]
    },
    "@bb/integration-tests#test:smoke": {
      "dependsOn": ["build", "^build"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/apps/server/package.json",
        "$TURBO_ROOT$/apps/server/tsconfig.json",
        "$TURBO_ROOT$/apps/server/src/**"
      ]
    },
    "test:e2b-smoke": {
      "dependsOn": ["typecheck", "^build"],
      "cache": false,
      "passThroughEnv": [
        "BB_CLOUD_AUTH_FIXTURE_PATH",
        "BB_E2B_SMOKE_REQUIRE_FULL_AUTH",
        "BB_E2B_TEMPLATE",
        "E2B_API_KEY"
      ]
    },
    "bench": {
      "dependsOn": ["build", "^build"]
    },
    "test:integration": {
      "dependsOn": ["build", "^build"]
    },
    "@bb/integration-tests#test:integration": {
      "dependsOn": ["build", "^build"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/apps/server/package.json",
        "$TURBO_ROOT$/apps/server/tsconfig.json",
        "$TURBO_ROOT$/apps/server/src/**"
      ]
    }
  }
}
