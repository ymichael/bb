{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "@bb/app#build": {
      "dependsOn": [],
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/apps/*/package.json",
        "$TURBO_ROOT$/apps/*/scripts/**",
        "$TURBO_ROOT$/apps/*/src/**",
        "$TURBO_ROOT$/apps/*/tsconfig.json",
        "$TURBO_ROOT$/apps/*/vite.config.ts",
        "$TURBO_ROOT$/package.json",
        "$TURBO_ROOT$/packages/*/package.json",
        "$TURBO_ROOT$/packages/*/src/**",
        "$TURBO_ROOT$/packages/*/tsconfig.json",
        "$TURBO_ROOT$/packages/db/drizzle/**",
        "$TURBO_ROOT$/packages/templates/scripts/**",
        "$TURBO_ROOT$/packages/tsconfig/*.json",
        "$TURBO_ROOT$/pnpm-lock.yaml",
        "$TURBO_ROOT$/pnpm-workspace.yaml",
        "$TURBO_ROOT$/scripts/*.mjs",
        "$TURBO_ROOT$/turbo.json"
      ],
      "outputs": ["dist/**"]
    },
    "@bb/cli#build": {
      "dependsOn": [],
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/apps/*/package.json",
        "$TURBO_ROOT$/apps/*/scripts/**",
        "$TURBO_ROOT$/apps/*/src/**",
        "$TURBO_ROOT$/apps/*/tsconfig.json",
        "$TURBO_ROOT$/apps/*/vite.config.ts",
        "$TURBO_ROOT$/package.json",
        "$TURBO_ROOT$/packages/*/package.json",
        "$TURBO_ROOT$/packages/*/src/**",
        "$TURBO_ROOT$/packages/*/tsconfig.json",
        "$TURBO_ROOT$/packages/db/drizzle/**",
        "$TURBO_ROOT$/packages/templates/scripts/**",
        "$TURBO_ROOT$/packages/tsconfig/*.json",
        "$TURBO_ROOT$/pnpm-lock.yaml",
        "$TURBO_ROOT$/pnpm-workspace.yaml",
        "$TURBO_ROOT$/scripts/*.mjs",
        "$TURBO_ROOT$/turbo.json"
      ],
      "outputs": ["dist/**"]
    },
    "@bb/host-daemon#build": {
      "dependsOn": [],
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/apps/*/package.json",
        "$TURBO_ROOT$/apps/*/scripts/**",
        "$TURBO_ROOT$/apps/*/src/**",
        "$TURBO_ROOT$/apps/*/tsconfig.json",
        "$TURBO_ROOT$/apps/*/vite.config.ts",
        "$TURBO_ROOT$/package.json",
        "$TURBO_ROOT$/packages/*/package.json",
        "$TURBO_ROOT$/packages/*/src/**",
        "$TURBO_ROOT$/packages/*/tsconfig.json",
        "$TURBO_ROOT$/packages/db/drizzle/**",
        "$TURBO_ROOT$/packages/templates/scripts/**",
        "$TURBO_ROOT$/packages/tsconfig/*.json",
        "$TURBO_ROOT$/pnpm-lock.yaml",
        "$TURBO_ROOT$/pnpm-workspace.yaml",
        "$TURBO_ROOT$/scripts/*.mjs",
        "$TURBO_ROOT$/turbo.json"
      ],
      "outputs": ["dist/**"]
    },
    "@bb/scripts#build": {
      "dependsOn": [],
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/apps/*/package.json",
        "$TURBO_ROOT$/apps/*/scripts/**",
        "$TURBO_ROOT$/apps/*/src/**",
        "$TURBO_ROOT$/apps/*/tsconfig.json",
        "$TURBO_ROOT$/apps/*/vite.config.ts",
        "$TURBO_ROOT$/package.json",
        "$TURBO_ROOT$/packages/*/package.json",
        "$TURBO_ROOT$/packages/*/src/**",
        "$TURBO_ROOT$/packages/*/tsconfig.json",
        "$TURBO_ROOT$/packages/db/drizzle/**",
        "$TURBO_ROOT$/packages/templates/scripts/**",
        "$TURBO_ROOT$/packages/tsconfig/*.json",
        "$TURBO_ROOT$/pnpm-lock.yaml",
        "$TURBO_ROOT$/pnpm-workspace.yaml",
        "$TURBO_ROOT$/scripts/*.mjs",
        "$TURBO_ROOT$/turbo.json"
      ],
      "outputs": ["dist/**"]
    },
    "@bb/server#build": {
      "dependsOn": [],
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/apps/*/package.json",
        "$TURBO_ROOT$/apps/*/scripts/**",
        "$TURBO_ROOT$/apps/*/src/**",
        "$TURBO_ROOT$/apps/*/tsconfig.json",
        "$TURBO_ROOT$/apps/*/vite.config.ts",
        "$TURBO_ROOT$/package.json",
        "$TURBO_ROOT$/packages/*/package.json",
        "$TURBO_ROOT$/packages/*/src/**",
        "$TURBO_ROOT$/packages/*/tsconfig.json",
        "$TURBO_ROOT$/packages/db/drizzle/**",
        "$TURBO_ROOT$/packages/templates/scripts/**",
        "$TURBO_ROOT$/packages/tsconfig/*.json",
        "$TURBO_ROOT$/pnpm-lock.yaml",
        "$TURBO_ROOT$/pnpm-workspace.yaml",
        "$TURBO_ROOT$/scripts/*.mjs",
        "$TURBO_ROOT$/turbo.json"
      ],
      "outputs": ["dist/**"]
    },
    "bb-app#build": {
      "dependsOn": [
        "@bb/app#build",
        "@bb/server#build",
        "@bb/host-daemon#build",
        "@bb/cli#build"
      ],
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/apps/app/dist/**",
        "$TURBO_ROOT$/apps/server/dist/**",
        "$TURBO_ROOT$/apps/host-daemon/dist/**",
        "$TURBO_ROOT$/packages/bb-app/package.json",
        "$TURBO_ROOT$/packages/bb-app/scripts/**",
        "$TURBO_ROOT$/packages/bb-app/src/**",
        "$TURBO_ROOT$/packages/bb-app/tsconfig.json",
        "$TURBO_ROOT$/packages/tsconfig/*.json",
        "$TURBO_ROOT$/scripts/*.mjs"
      ],
      "outputs": ["app/**", "dist/**", "host-daemon/**", "server/**"]
    },
    "bundle": {
      "dependsOn": [],
      "cache": false,
      "outputs": []
    },
    "template:build": {
      "dependsOn": [],
      "cache": false,
      "outputs": [],
      "passThroughEnv": ["E2B_API_KEY"]
    },
    "@bb/app#dev": {
      "dependsOn": [],
      "cache": false,
      "persistent": true,
      "passThroughEnv": ["*"]
    },
    "storybook": {
      "dependsOn": [],
      "cache": false,
      "persistent": true,
      "passThroughEnv": ["*"]
    },
    "@bb/dev-env#dev": {
      "dependsOn": [],
      "cache": false,
      "persistent": true,
      "passThroughEnv": ["*"]
    },
    "@bb/host-daemon#dev": {
      "dependsOn": [],
      "cache": false,
      "persistent": true,
      "passThroughEnv": ["*"]
    },
    "@bb/server#dev": {
      "dependsOn": [],
      "cache": false,
      "persistent": true,
      "passThroughEnv": ["*"]
    },
    "@bb/host-daemon#start:prod": {
      "dependsOn": ["build"],
      "cache": false,
      "persistent": true,
      "passThroughEnv": ["*"]
    },
    "@bb/server#start:prod": {
      "dependsOn": ["build"],
      "cache": false,
      "persistent": true,
      "passThroughEnv": ["*"]
    },
    "clean": {
      "cache": false
    },
    "lint": {},
    "typecheck": {
      "dependsOn": []
    },
    "@bb/integration-tests#typecheck": {
      "dependsOn": [],
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/apps/server/package.json",
        "$TURBO_ROOT$/apps/server/tsconfig.json",
        "$TURBO_ROOT$/apps/server/src/**"
      ]
    },
    "test": {
      "dependsOn": []
    },
    "smoke:tarball": {
      "dependsOn": ["build"],
      "cache": false,
      "outputs": []
    },
    "@bb/integration-tests#test": {
      "dependsOn": [],
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/apps/server/package.json",
        "$TURBO_ROOT$/apps/server/tsconfig.json",
        "$TURBO_ROOT$/apps/server/src/**"
      ]
    },
    "test:smoke": {
      "dependsOn": []
    },
    "@bb/integration-tests#test:smoke": {
      "dependsOn": [],
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/apps/server/package.json",
        "$TURBO_ROOT$/apps/server/tsconfig.json",
        "$TURBO_ROOT$/apps/server/src/**"
      ]
    },
    "test:e2b-smoke": {
      "dependsOn": ["typecheck"],
      "cache": false,
      "passThroughEnv": [
        "BB_CLOUD_AUTH_FIXTURE_PATH",
        "BB_E2B_SMOKE_REQUIRE_FULL_AUTH",
        "BB_E2B_TEMPLATE",
        "E2B_API_KEY"
      ]
    },
    "bench": {
      "dependsOn": []
    },
    "test:integration": {
      "dependsOn": []
    },
    "@bb/integration-tests#test:integration": {
      "dependsOn": ["@bb/agent-runtime#test:integration"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/apps/server/package.json",
        "$TURBO_ROOT$/apps/server/tsconfig.json",
        "$TURBO_ROOT$/apps/server/src/**"
      ]
    }
  }
}
