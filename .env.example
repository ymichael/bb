# Copy this file to .env and uncomment only the values you need to override.

# Runtime state. Defaults:
# - pnpm start: ~/.bb
# - pnpm dev: ~/.bb-dev
# BB_DATA_DIR=~/.bb

# Production-mode ports used by pnpm start.
# BB_SERVER_PORT=38886
# BB_HOST_DAEMON_PORT=38887

# Human-facing app URL for generated links and allowed browser origins.
# Leave empty for local-only use.
# BB_APP_URL=

# Recommended for full local functionality:
# - default server-side helpers with BB_INFERENCE_MODEL=openai/gpt-4o-mini
# - voice input transcription
# Codex CLI sessions can also use codex login; this key is for bb server features.
# OPENAI_API_KEY=

# Optional provider/API credentials used by alternate inference providers.
# ANTHROPIC_API_KEY=

# Server-side inference model for generated titles, commit messages, and similar helpers.
# BB_INFERENCE_MODEL=openai/gpt-4o-mini
