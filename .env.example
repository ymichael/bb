# BB local development environment
# Copy this file to .env and fill in the values you need.
# .env is gitignored and will be loaded automatically by `pnpm dev`.

# ---------------------------------------------------------------------------
# Provider selection
# ---------------------------------------------------------------------------
# Which agent provider the daemon uses. Supported: "codex", "claude-code", "pi"
# BB_PROVIDER=codex

# ---------------------------------------------------------------------------
# Claude Code authentication (required when BB_PROVIDER=claude-code)
# ---------------------------------------------------------------------------
# Option 1: OAuth token from a Claude subscription.
# Generate one with: claude setup-token
# CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-...

# Option 2: Anthropic API key from console.anthropic.com
# ANTHROPIC_API_KEY=sk-ant-api03-...

# Option 3: Cloud provider (set one of these to "1" and configure
# the provider's own credentials via standard env vars / config).
# CLAUDE_CODE_USE_BEDROCK=1
# CLAUDE_CODE_USE_VERTEX=1
# CLAUDE_CODE_USE_FOUNDRY=1

# ---------------------------------------------------------------------------
# Pi authentication (required when BB_PROVIDER=pi)
# ---------------------------------------------------------------------------
# Pi reads credentials from ~/.pi/agent/auth.json by default, supporting
# OAuth (Claude Pro/Max, ChatGPT Plus/Pro, GitHub Copilot) and API keys.
# Run `npx @mariozechner/pi-ai login` for interactive setup.
# No env vars are needed unless you want to override the auth file.

# ---------------------------------------------------------------------------
# Codex authentication (required when BB_PROVIDER=codex)
# ---------------------------------------------------------------------------
# Codex reads credentials from ~/.codex/auth.json by default.
# Override with these if needed:
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1

# ---------------------------------------------------------------------------
# Daemon configuration
# ---------------------------------------------------------------------------
# Custom data root (default: ~/.bb)
# BB_ROOT=/path/to/bb-root

# Custom database path (default: $BB_ROOT/bb.db)
# BB_DB_PATH=/path/to/bb.db

# Default environment type for new threads: "local", "worktree", or "docker"
# BB_ENVIRONMENT=local

# Custom root directory for managed worktrees
# BB_WORKTREE_ROOT=/path/to/worktrees

# ---------------------------------------------------------------------------
# LLM inference (used for title generation, commit messages, etc.)
# ---------------------------------------------------------------------------
# Override the model used for LLM completions (not the agent provider model)
# BB_INFERENCE_MODEL=gpt-4o-mini

# ---------------------------------------------------------------------------
# Voice transcription (optional)
# ---------------------------------------------------------------------------
# OpenAI API key for voice transcription (Whisper). Falls back to
# OPENAI_API_KEY above if not set separately.
# OPENAI_API_KEY=sk-...

# ---------------------------------------------------------------------------
# Environment agent timing (advanced — for testing/debugging only)
# ---------------------------------------------------------------------------
# BB_ENV_DAEMON_LEASE_TTL_MS=30000
# BB_ENV_DAEMON_HEARTBEAT_INTERVAL_MS=10000
# BB_ENV_DAEMON_COMMAND_LONG_POLL_TIMEOUT_MS=25000
# BB_ENV_DAEMON_COMMAND_LONG_POLL_INTERVAL_MS=1000
# BB_ENV_DAEMON_LEASE_SWEEP_INTERVAL_MS=5000
# BB_ENV_DAEMON_STARTUP_RECOVERY_REQUEST_TIMEOUT_MS=5000

# ---------------------------------------------------------------------------
# Debugging
# ---------------------------------------------------------------------------
# Enable performance debug logging
# BB_DEBUG_PERF=1
