{
  "name": "bb",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "turbo run dev --ui tui --concurrency 20",
    "build": "turbo run build",
    "start": "turbo run build --filter=@bb/app --filter=@bb/cli && turbo run start:prod --filter=@bb/server --filter=@bb/host-daemon --concurrency 20",
    "reset": "BB_DATA_DIR=${BB_DATA_DIR:-$HOME/.bb} node scripts/reset-bb-data.mjs",
    "reset:dev": "BB_DATA_DIR=${BB_DATA_DIR:-$HOME/.bb-dev} node scripts/reset-bb-data.mjs",
    "reset:all": "node scripts/reset-bb-data.mjs --all",
    "clean": "turbo run clean",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:integration": "turbo run test:integration test:e2e",
    "test:e2e": "turbo run test:e2e",
    "bb": "node apps/cli/dist/index.js",
    "bb:dev": "pnpm --filter @bb/server exec tsx ../cli/src/index.ts",
    "server": "pnpm --filter @bb/server start",
    "drizzle-studio": "pnpm --filter @bb/db db:studio"
  },
  "devDependencies": {
    "turbo": "^2.4.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  },
  "packageManager": "pnpm@9.15.0"
}
