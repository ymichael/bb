{
  "name": "beanbag",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "turbo run dev --ui tui",
    "build": "turbo run build",
    "clean": "turbo run clean",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "vitest run",
    "test:integration": "pnpm --filter @beanbag/environment test:integration && pnpm --filter @beanbag/daemon test:e2e",
    "test:e2e": "pnpm --filter @beanbag/daemon test:e2e",
    "bb": "node apps/cli/dist/index.js",
    "bb:dev": "pnpm --filter @beanbag/daemon exec tsx ../cli/src/index.ts",
    "daemon": "node apps/daemon/dist/index.js",
    "drizzle-studio": "pnpm --filter @beanbag/db db:studio"
  },
  "devDependencies": {
    "turbo": "^2.4.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  },
  "packageManager": "pnpm@9.15.0"
}
