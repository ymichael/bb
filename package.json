{
  "name": "bb",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "git config core.hooksPath .githooks",
    "dev": "BB_ROOT=${BB_ROOT:-$HOME/.bb-dev} BB_SERVER_PORT=${BB_SERVER_PORT:-3334} BB_APP_PORT=${BB_APP_PORT:-5173} turbo run dev --ui tui --concurrency 20",
    "build": "turbo run build",
    "start": "pnpm exec turbo run build --filter=@bb/app --filter=@bb/server --filter=@bb/cli && node apps/server/dist/index.js",
    "precommit:build": "pnpm build",
    "clean": "turbo run clean",
    "lint": "turbo run lint",
    "check:package-entrypoints": "node scripts/check-package-entrypoints.mjs",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:integration": "turbo run test:integration test:e2e",
    "test:e2e": "turbo run test:e2e",
    "qa:server:manual-smoke": "node scripts/qa/run-standalone-server-manual-smoke.mjs",
    "qa:server:smoke": "BB_E2E_PROVIDER_MODE=real pnpm --filter @bb/server test:e2e:qa:smoke",
    "qa:server:stress": "BB_E2E_PROVIDER_MODE=real pnpm --filter @bb/server test:e2e:qa:stress",
    "qa:server:regression": "BB_E2E_PROVIDER_MODE=real pnpm --filter @bb/server test:e2e:qa:regression",
    "qa:server:smoke:claude-code": "BB_E2E_PROVIDER_MODE=real BB_E2E_PROVIDER=claude-code pnpm --filter @bb/server test:e2e:qa:smoke",
    "qa:server:smoke:pi": "BB_E2E_PROVIDER_MODE=real BB_E2E_PROVIDER=pi pnpm --filter @bb/server test:e2e:qa:smoke",
    "qa:server:recovery:fake": "BB_E2E_PROVIDER_MODE=fake pnpm --filter @bb/server test:e2e:qa:recovery:fake",
    "bb": "node apps/cli/dist/index.js",
    "bb:dev": "BB_SERVER_URL=${BB_SERVER_URL:-http://localhost:3334} pnpm --filter @bb/server exec tsx ../cli/src/index.ts",
    "server": "node apps/server/dist/index.js",
    "drizzle-studio": "pnpm --filter @bb/db db:studio"
  },
  "devDependencies": {
    "turbo": "^2.4.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  },
  "packageManager": "pnpm@9.15.0"
}
