{
  "name": "bb",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "dotenv -c development -- turbo run dev --ui tui --concurrency 20 --no-update-notifier",
    "dev:restart": "dotenv -c development -- node scripts/request-dev-restart.mjs both",
    "dev:restart-server": "dotenv -c development -- node scripts/request-dev-restart.mjs server",
    "dev:restart-host-daemon": "dotenv -c development -- node scripts/request-dev-restart.mjs host-daemon",
    "dev:host-daemon": "pnpm exec turbo run build --filter=@bb/host-daemon --filter=@bb/cli && node scripts/run-host-daemon.mjs --mode dev --auto-join",
    "build": "turbo run build",
    "start": "cross-env NODE_ENV=production dotenv -c production -- node scripts/start-bb.mjs",
    "start:host-daemon": "cross-env NODE_ENV=production node scripts/start-host-daemon.mjs",
    "reset": "node scripts/reset-bb-data.mjs --mode prod",
    "reset:dev": "node scripts/reset-bb-data.mjs --mode dev",
    "reset:all": "node scripts/reset-bb-data.mjs --all",
    "clean": "turbo run clean",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:integration": "turbo run test:integration test:e2e",
    "test:e2e": "turbo run test:e2e",
    "bb": "node apps/cli/dist/index.js",
    "bb:dev": "cross-env BB_SERVER_URL=http://localhost:3334 BB_HOST_DAEMON_PORT=3002 pnpm --filter @bb/server exec tsx ../cli/src/index.ts",
    "server": "pnpm --filter @bb/server start",
    "drizzle-studio": "pnpm --filter @bb/db db:studio"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "cross-spawn": "^7.0.6",
    "dotenv-cli": "^11.0.0",
    "open": "^10.2.0",
    "rimraf": "^6.1.0",
    "turbo": "^2.4.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  },
  "packageManager": "pnpm@9.15.0"
}
