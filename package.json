{
  "name": "beanbag",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "git config core.hooksPath .githooks",
    "dev": "turbo run dev --ui tui",
    "build": "turbo run build",
    "precommit:build": "pnpm build",
    "clean": "turbo run clean",
    "lint": "turbo run lint",
    "check:package-entrypoints": "node scripts/check-package-entrypoints.mjs",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:integration": "turbo run test:integration test:e2e",
    "test:e2e": "turbo run test:e2e",
    "qa:daemon:smoke": "pnpm --filter @beanbag/daemon test:e2e:qa:smoke",
    "qa:daemon:stress": "pnpm --filter @beanbag/daemon test:e2e:qa:stress",
    "qa:daemon:regression": "pnpm --filter @beanbag/daemon test:e2e:qa:regression",
    "bb": "node apps/cli/dist/index.js",
    "bb:dev": "pnpm --filter @beanbag/daemon exec tsx ../cli/src/index.ts",
    "daemon": "node apps/daemon/dist/index.js",
    "drizzle-studio": "pnpm --filter @beanbag/db db:studio"
  },
  "devDependencies": {
    "turbo": "^2.4.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  },
  "packageManager": "pnpm@9.15.0"
}
