    import React from "react";
    import { vi } from "vitest";

    import { DiagramToCodePlugin, Excalidraw } from "../../index";
    import { updateTextEditor } from "../../tests/queries/dom";
    import {
      act,
      fireEvent,
      render,
      screen,
      waitFor,
      withExcalidrawDimensions,
    } from "../../tests/test-utils";

    const MAGIC_FRAME_LABEL = "Wireframe to code";
    const COMMAND_PALETTE_PLACEHOLDER =
      "Search menus, commands, and discover hidden gems";

    const openCommandPalette = async () => {
      act(() => {
        window.h.app.setOpenDialog({ name: "commandPalette" });
      });

      return (await screen.findByPlaceholderText(
        COMMAND_PALETTE_PLACEHOLDER,
      )) as HTMLInputElement;
    };

    describe("CommandPalette", () => {
      afterEach(() => {
        vi.restoreAllMocks();
      });

      it.each([
        {
          name: "AI is disabled",
          aiEnabled: false,
          withPlugin: true,
        },
        {
          name: "diagram to code is unavailable",
          aiEnabled: true,
          withPlugin: false,
        },
      ])("should hide Magic Frame when $name", async ({ aiEnabled, withPlugin }) => {
        await render(
          <Excalidraw aiEnabled={aiEnabled}>
            {withPlugin ? (
              <DiagramToCodePlugin
                generate={async () => ({
                  html: "<!DOCTYPE html><html><body></body></html>",
                })}
              />
            ) : null}
          </Excalidraw>,
        );

        await withExcalidrawDimensions({ width: 1920, height: 1080 }, async () => {
          const input = await openCommandPalette();
          updateTextEditor(input, "magic");

          await waitFor(() => {
            expect(screen.queryByText(MAGIC_FRAME_LABEL)).not.toBeInTheDocument();
          });
        });
      });

      it("should make Magic Frame searchable and wire it to the existing action", async () => {
        await render(
          <Excalidraw>
            <DiagramToCodePlugin
              generate={async () => ({
                html: "<!DOCTYPE html><html><body></body></html>",
              })}
            />
          </Excalidraw>,
        );

