{
  "name": "@beanbag/environment-agent",
  "version": "0.0.1",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./src/index.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "files": ["dist"],
  "scripts": {
    "build": "rm -rf dist tsconfig.tsbuildinfo && tsc && pnpm exec esbuild src/bin/environment-agent.ts --bundle --platform=node --target=node22 --format=esm --outfile=dist/environment-agent.bundle.mjs",
    "dev": "tsc --watch --preserveWatchOutput",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --config vitest.config.ts"
  },
  "devDependencies": {
    "@beanbag/tsconfig": "workspace:*",
    "@types/node": "^22.0.0",
    "esbuild": "^0.25.11",
    "typescript": "^5.7.0",
    "vitest": "^4.0.0"
  }
}
