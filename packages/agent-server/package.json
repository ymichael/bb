{
  "name": "@beanbag/agent-server",
  "version": "0.0.1",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch --preserveWatchOutput",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --config vitest.config.ts"
  },
  "dependencies": {
    "@beanbag/agent-core": "workspace:*",
    "@anthropic-ai/sdk": "^0.73.0",
    "@beanbag/claude-code-bridge": "workspace:*",
    "@beanbag/environment-agent": "workspace:*",
    "@beanbag/pi-bridge": "workspace:*",
    "@beanbag/templates": "workspace:*",
    "@mariozechner/pi-ai": "^0.58.3",
    "@mariozechner/pi-coding-agent": "^0.58.3",
    "tsx": "^4.20.0"
  },
  "devDependencies": {
    "@beanbag/tsconfig": "workspace:*",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.0"
  }
}
