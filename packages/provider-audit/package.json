{
  "name": "@bb/provider-audit",
  "version": "0.0.1",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "bb-provider-audit": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rimraf dist tsconfig.tsbuildinfo && tsc",
    "clean": "rimraf dist tsconfig.tsbuildinfo",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --config vitest.config.ts",
    "ladle:prepare": "pnpm exec turbo run build --filter=@bb/provider-audit --filter=@bb/ui-core --filter=@bb/core-ui --filter=@bb/domain --filter=@bb/agent-runtime && node ./dist/cli.js export-ladle-data --output ./.ladle/fixture-story-data.ts",
    "ladle": "pnpm run ladle:prepare && ladle serve",
    "ladle:build": "pnpm run ladle:prepare && ladle build"
  },
  "dependencies": {
    "@bb/agent-runtime": "workspace:*",
    "@bb/core-ui": "workspace:*",
    "@bb/domain": "workspace:*",
    "@bb/ui-core": "workspace:*",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@bb/tsconfig": "workspace:*",
    "@ladle/react": "^5.0.3",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
