{
  "name": "@bb/agent-runtime",
  "version": "0.0.1",
  "type": "module",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./capture": {
      "source": "./src/capture.ts",
      "types": "./src/capture.ts",
      "default": "./src/capture.ts"
    },
    "./shared/json-rpc-envelope": {
      "source": "./src/shared/json-rpc-envelope.ts",
      "types": "./src/shared/json-rpc-envelope.ts",
      "default": "./src/shared/json-rpc-envelope.ts"
    },
    "./test": {
      "source": "./src/test/index.ts",
      "types": "./src/test/index.ts",
      "default": "./src/test/index.ts"
    }
  },
  "types": "./src/index.ts",
  "scripts": {
    "clean": "rimraf dist tsconfig.tsbuildinfo",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --config vitest.config.ts",
    "test:unit": "vitest run --config vitest.config.ts --exclude '**/integration/**'",
    "test:integration": "vitest run --config vitest.integration.config.ts"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.111",
    "@bb/agent-providers": "workspace:*",
    "@bb/domain": "workspace:*",
    "@bb/process-utils": "workspace:*",
    "@mariozechner/pi-ai": "^0.70.5",
    "@mariozechner/pi-coding-agent": "^0.70.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@bb/test-helpers": "workspace:*",
    "@bb/tsconfig": "workspace:*",
    "@types/node": "^22.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.1"
  }
}
