{
  "name": "@bb/ui-core",
  "version": "0.0.1",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./theme.css": "./src/primitives/theme.css"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src/primitives/theme.css"
  ],
  "scripts": {
    "build": "rimraf dist tsconfig.build.tsbuildinfo && tsc -p tsconfig.build.json",
    "clean": "rimraf dist build tsconfig.tsbuildinfo",
    "ladle": "ladle serve",
    "ladle:build": "ladle build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --config vitest.config.ts"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "dependencies": {
    "@bb/core-ui": "workspace:*",
    "@bb/domain": "workspace:*",
