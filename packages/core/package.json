{
  "name": "@bb/core",
  "version": "0.0.1",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./storage-paths": {
      "import": "./dist/storage-paths.js",
      "types": "./dist/storage-paths.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "rm -rf dist tsconfig.tsbuildinfo && tsc",
    "dev": "tsc --watch --preserveWatchOutput",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --config vitest.config.ts",
    "gen:codex-event-types": "node ./scripts/generate-codex-event-types.mjs"
  },
  "dependencies": {
    "@bb/templates": "workspace:*",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@bb/tsconfig": "workspace:*",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  }
}
