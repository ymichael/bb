{
  "name": "@bb/db",
  "version": "0.0.1",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./internal-lifecycle": {
      "import": "./dist/internal-lifecycle.js",
      "types": "./dist/internal-lifecycle.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "drizzle"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rimraf dist tsconfig.tsbuildinfo",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --config vitest.config.ts",
    "predb:generate": "pnpm exec turbo run build --filter=@bb/db",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@bb/domain": "workspace:*",
    "better-sqlite3": "^11.7.0",
    "drizzle-orm": "^0.38.0",
    "nanoid": "^5.0.9"
  },
  "devDependencies": {
    "@bb/tsconfig": "workspace:*",
    "@types/better-sqlite3": "^7.6.12",
    "drizzle-kit": "^0.30.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.1"
  }
}
