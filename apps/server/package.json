{
  "name": "@bb/server",
  "version": "0.0.1",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./src/index.ts"
    },
    "./app-type": {
      "types": "./src/app-type.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "node scripts/dev-supervisor.mjs --port ${BB_SERVER_PORT:-3334}",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "pnpm test:unit && pnpm test:e2e",
    "test:unit": "vitest run",
    "test:e2e": "pnpm test:e2e:smoke",
    "test:e2e:smoke": "vitest run --config vitest.e2e.fast.config.ts",
    "test:e2e:stress": "vitest run --config vitest.e2e.stress.config.ts",
    "test:e2e:qa:smoke": "BB_E2E_PROVIDER_MODE=real vitest run --config vitest.e2e.fast.config.ts src/__tests__/e2e/standalone-server-cli-roundtrip.test.ts src/__tests__/e2e/standalone-server-blocked-restart.test.ts src/__tests__/e2e/thread-immediate-followups-roundtrip.test.ts src/__tests__/e2e/thread-worktree-followup-roundtrip.test.ts src/__tests__/e2e/thread-worktree-primary-checkout-roundtrip.test.ts src/__tests__/e2e/thread-shared-environment-roundtrip.test.ts src/__tests__/e2e/dynamic-tools-server-roundtrip.test.ts",
    "test:e2e:qa:stress": "BB_E2E_PROVIDER_MODE=real vitest run --config vitest.e2e.fast.config.ts src/__tests__/e2e/environment-daemon-restart-roundtrip.test.ts src/__tests__/e2e/thread-restart-recovery-matrix.test.ts src/__tests__/e2e/thread-recovery-heavy-runbook.test.ts src/__tests__/e2e/thread-archive-unarchive-roundtrip.test.ts src/__tests__/e2e/thread-provisioning-responsiveness.test.ts",
    "test:e2e:qa:regression": "BB_E2E_PROVIDER_MODE=real vitest run --config vitest.e2e.fast.config.ts src/__tests__/e2e/thread-immediate-followups-roundtrip.test.ts src/__tests__/e2e/thread-archive-unarchive-roundtrip.test.ts src/__tests__/e2e/environment-daemon-restart-roundtrip.test.ts src/__tests__/e2e/thread-restart-recovery-matrix.test.ts src/__tests__/e2e/thread-recovery-heavy-runbook.test.ts src/__tests__/e2e/thread-worktree-primary-checkout-roundtrip.test.ts src/__tests__/e2e/thread-shared-environment-roundtrip.test.ts src/__tests__/e2e/thread-multi-provider-shared-environment.test.ts",
    "test:e2e:qa:multi-provider": "BB_E2E_PROVIDER_MODE=real vitest run --config vitest.e2e.fast.config.ts src/__tests__/e2e/thread-multi-provider-shared-environment.test.ts",
    "test:e2e:qa:recovery:fake": "node ../../scripts/qa/run-fake-recovery-suite.mjs",
    "test:e2e:real": "BB_E2E_PROVIDER_MODE=real pnpm test:e2e:smoke",
    "test:e2e:stress:real": "BB_E2E_PROVIDER_MODE=real pnpm test:e2e:stress",
    "test:e2e:docker": "vitest run --config vitest.e2e.config.ts src/__tests__/e2e/docker-thread-roundtrip.test.ts",
    "test:e2e:all": "vitest run --config vitest.e2e.config.ts --dir src/__tests__/e2e"
  },
  "dependencies": {
    "@bb/core": "workspace:*",
    "@bb/db": "workspace:*",
    "@bb/environment": "workspace:*",
    "@bb/environment-daemon": "workspace:*",
    "@bb/provider-adapters": "workspace:*",
    "@bb/templates": "workspace:*",
    "@hono/node-server": "^1.13.0",
    "@hono/node-ws": "^1.1.0",
    "@hono/zod-validator": "^0.4.0",
    "dotenv": "^17.3.1",
    "hono": "^4.7.0",
    "xstate": "^5.20.2",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@bb/tsconfig": "workspace:*",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
