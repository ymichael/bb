{
  "name": "@beanbag/daemon",
  "version": "0.0.1",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./src/index.ts"
    },
    "./app-type": {
      "types": "./src/app-type.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "node scripts/dev-supervisor.mjs",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "pnpm test:unit && pnpm test:e2e",
    "test:unit": "vitest run",
    "test:e2e": "vitest run --config vitest.e2e.fast.config.ts",
    "test:e2e:qa:smoke": "vitest run --config vitest.e2e.fast.config.ts src/__tests__/e2e/standalone-daemon-cli-roundtrip.test.ts src/__tests__/e2e/thread-immediate-followups-roundtrip.test.ts src/__tests__/e2e/thread-worktree-followup-roundtrip.test.ts",
    "test:e2e:qa:stress": "vitest run --config vitest.e2e.fast.config.ts src/__tests__/e2e/environment-agent-restart-roundtrip.test.ts src/__tests__/e2e/thread-archive-unarchive-roundtrip.test.ts src/__tests__/e2e/thread-provisioning-responsiveness.test.ts",
    "test:e2e:qa:regression": "vitest run --config vitest.e2e.fast.config.ts src/__tests__/e2e/thread-immediate-followups-roundtrip.test.ts src/__tests__/e2e/thread-archive-unarchive-roundtrip.test.ts src/__tests__/e2e/environment-agent-restart-roundtrip.test.ts",
    "test:e2e:real": "BEANBAG_E2E_PROVIDER_MODE=real vitest run --config vitest.e2e.fast.config.ts",
    "test:e2e:docker": "vitest run --config vitest.e2e.config.ts src/__tests__/e2e/docker-thread-roundtrip.test.ts",
    "test:e2e:all": "vitest run --config vitest.e2e.config.ts --dir src/__tests__/e2e"
  },
  "dependencies": {
    "@beanbag/agent-core": "workspace:*",
    "@beanbag/environment": "workspace:*",
    "@beanbag/environment-agent": "workspace:*",
    "@beanbag/agent-server": "workspace:*",
    "@beanbag/db": "workspace:*",
    "@hono/node-server": "^1.13.0",
    "@hono/node-ws": "^1.1.0",
    "@hono/zod-validator": "^0.4.0",
    "hono": "^4.7.0",
    "xstate": "^5.20.2",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@beanbag/tsconfig": "workspace:*",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
