{
  "name": "@bb/host-daemon",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "exports": {
    "./test": {
      "source": "./src/test/index.ts",
      "types": "./src/test/index.ts",
      "default": "./src/test/index.ts"
    }
  },
  "scripts": {
    "build": "node ../../scripts/build-node-entry.mjs src/index.ts dist/index.js --clean-dist --templates && node ./scripts/build-bundles.mjs",
    "bundle": "node ./scripts/build-bundles.mjs",
    "bundle:check": "node ./scripts/check-bundles.mjs",
    "start": "node dist/index.js",
    "start:prod": "cross-env NODE_ENV=production node dist/index.js",
    "dev": "node --conditions=source --import tsx scripts/dev-supervisor.mjs",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --config vitest.config.ts"
  },
  "dependencies": {
    "@bb/agent-runtime": "workspace:*",
    "@bb/cli": "workspace:*",
    "@bb/config": "workspace:*",
    "@bb/domain": "workspace:*",
    "@bb/fuzzy-match": "workspace:*",
    "@bb/host-daemon-contract": "workspace:*",
    "@bb/host-runtime-material": "workspace:*",
    "@bb/host-watcher": "workspace:*",
    "@bb/host-workspace": "workspace:*",
    "@bb/logger": "workspace:*",
    "@bb/process-utils": "workspace:*",
    "@bb/replay-capture": "workspace:*",
    "@bb/templates": "workspace:*",
    "@hono/node-server": "^1.19.11",
    "@parcel/watcher": "2.5.6",
    "better-sqlite3": "^11.7.0",
    "mime-types": "^3.0.2",
    "open": "^10.2.0",
    "p-debounce": "^5.1.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "pino-roll": "^4.0.0",
    "p-retry": "^6.2.1",
    "partysocket": "^1.1.16",
    "proper-lockfile": "^4.1.2",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@bb/scripts": "workspace:*",
    "@bb/test-helpers": "workspace:*",
    "@bb/tsconfig": "workspace:*",
    "@types/better-sqlite3": "^7.6.12",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^22.0.0",
    "esbuild": "^0.25.0",
    "hono": "^4.7.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0"
  }
}
