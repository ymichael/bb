{
  "name": "@bb/host-daemon",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "exports": {
    "./test": {
      "import": "./dist/test/index.js",
      "types": "./dist/test/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "bundle": "node ./scripts/build-bundles.mjs",
    "bundle:check": "node ./scripts/check-bundles.mjs",
    "start": "node dist/index.js",
    "start:prod": "cross-env NODE_ENV=production node dist/index.js",
    "dev": "node scripts/dev-supervisor.mjs",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --config vitest.config.ts"
  },
  "dependencies": {
    "@bb/agent-runtime": "workspace:*",
    "@bb/cli": "workspace:*",
    "@bb/config": "workspace:*",
    "@bb/domain": "workspace:*",
    "@bb/host-daemon-contract": "workspace:*",
    "@bb/host-watcher": "workspace:*",
    "@bb/host-workspace": "workspace:*",
    "@bb/logger": "workspace:*",
    "@bb/templates": "workspace:*",
    "@hono/node-server": "^1.19.11",
    "mime-types": "^3.0.2",
    "p-debounce": "^5.1.0",
    "p-retry": "^6.2.1",
    "partysocket": "^1.1.16",
    "proper-lockfile": "^4.1.2",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@bb/test-helpers": "workspace:*",
    "@bb/tsconfig": "workspace:*",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^22.0.0",
    "esbuild": "^0.25.0",
    "hono": "^4.7.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0"
  }
}
